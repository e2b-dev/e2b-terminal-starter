# `stripe projects env --pull` writes the E2B API key for the e2b/sandbox service.
E2B_API_KEY=

# Optional overrides.
E2B_TEMPLATE=base
E2B_TIMEOUT_MS=300000
APP_DATABASE_PATH=./data/app.db
APP_SESSION_SECRET=

# Local starter auth only works on localhost unless this is set to true.
# Replace it with real auth before deploying a shared app.
APP_ENABLE_LOCAL_AUTH=
